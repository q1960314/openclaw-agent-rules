{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Strategy Expert Result Schema",
  "required": [
    "task_id",
    "objective",
    "recommendation",
    "problem_statement",
    "hypotheses",
    "candidate_solutions",
    "solution_comparison",
    "recommended_solution",
    "recommendation_basis",
    "applicability_conditions",
    "code_touchpoints",
    "change_priority",
    "backtest_handoff",
    "parameter_handoff",
    "factor_handoff",
    "failure_scenarios",
    "validation_path",
    "validation_priority",
    "risk_notes",
    "target_files"
  ],
  "properties": {
    "task_id": { "type": "string" },
    "objective": { "type": "string" },
    "mode": { "type": "string" },
    "model": { "type": "string" },
    "recommendation": { "type": "string" },
    "problem_statement": { "type": "string" },
    "hypotheses": { "type": "array", "items": { "type": "string" } },
    "candidate_solutions": { "type": "array", "items": { "type": "string" } },
    "solution_comparison": { "type": "array", "items": { "type": "string" } },
    "recommended_solution": { "type": "string" },
    "recommendation_basis": { "type": "array", "items": { "type": "string" } },
    "why_not_others": { "type": "string" },
    "applicability_conditions": { "type": "array", "items": { "type": "string" } },
    "code_touchpoints": { "type": "array", "items": { "type": "string" } },
    "change_priority": { "type": "array", "items": { "type": "string" } },
    "backtest_handoff": { "type": "array", "items": { "type": "string" } },
    "parameter_handoff": { "type": "array", "items": { "type": "string" } },
    "factor_handoff": { "type": "array", "items": { "type": "string" } },
    "failure_scenarios": { "type": "array", "items": { "type": "string" } },
    "validation_path": { "type": "array", "items": { "type": "string" } },
    "validation_priority": { "type": "array", "items": { "type": "string" } },
    "risk_notes": { "type": "array", "items": { "type": "string" } },
    "target_files": { "type": "array", "items": { "type": "string" } },
    "depth_metrics": { "type": "object" }
  },
  "additionalProperties": true
}
