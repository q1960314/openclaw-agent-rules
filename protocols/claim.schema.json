{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "P1 Claim Schema",
  "required": [
    "task_id",
    "claimed_by",
    "attempt",
    "status",
    "claimed_at"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "claimed_by": {
      "type": [
        "string",
        "null"
      ]
    },
    "attempt": {
      "type": "integer",
      "minimum": 0
    },
    "status": {
      "type": "string",
      "enum": [
        "unclaimed",
        "claimed",
        "released",
        "failed",
        "completed"
      ]
    },
    "claimed_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "lease_until": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "additionalProperties": true
}