{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "P1 Result Envelope Schema",
  "required": ["task_id", "from_role", "to_role", "status", "artifacts", "generated_at", "result_tier", "approval_state", "formalization_required", "manual_review_required"],
  "properties": {
    "task_id": {"type": "string"},
    "from_role": {"type": "string"},
    "to_role": {"type": "string"},
    "status": {"type": "string"},
    "summary": {"type": "string"},
    "artifacts": {"type": "array", "items": {"type": "string"}},
    "generated_at": {"type": "string", "format": "date-time"},
    "result_tier": {"type": "string", "enum": ["candidate", "official"]},
    "approval_state": {"type": "string", "enum": ["manual_review_required", "technically_validated_candidate", "officially_approved"]},
    "formalization_required": {"type": "boolean"},
    "manual_review_required": {"type": "boolean"},
    "review_decision": {"type": "string"}
  },
  "additionalProperties": true
}
