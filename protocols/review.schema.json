{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "P1 Review Schema",
  "required": [
    "task_id",
    "reviewed_by",
    "decision",
    "issues",
    "evidence"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "reviewed_by": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": [
        "passed",
        "rejected",
        "needs_changes",
        "manual_review_required"
      ]
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}