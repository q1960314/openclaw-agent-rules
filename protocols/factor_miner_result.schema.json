{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Factor Miner Result Schema",
  "required": [
    "task_id",
    "objective",
    "factor_summary",
    "factor_hypotheses",
    "economic_rationales",
    "candidate_factors",
    "applicability_conditions",
    "code_touchpoints",
    "strategy_handoff",
    "parameter_handoff",
    "failure_scenarios",
    "validation_plan",
    "validation_priority",
    "overlap_risks",
    "recommendation",
    "target_files"
  ],
  "properties": {
    "task_id": { "type": "string" },
    "objective": { "type": "string" },
    "mode": { "type": "string" },
    "model": { "type": "string" },
    "factor_summary": { "type": "string" },
    "factor_hypotheses": { "type": "array", "items": { "type": "string" } },
    "economic_rationales": { "type": "array", "items": { "type": "string" } },
    "candidate_factors": { "type": "array", "items": { "type": "string" } },
    "applicability_conditions": { "type": "array", "items": { "type": "string" } },
    "code_touchpoints": { "type": "array", "items": { "type": "string" } },
    "strategy_handoff": { "type": "array", "items": { "type": "string" } },
    "parameter_handoff": { "type": "array", "items": { "type": "string" } },
    "failure_scenarios": { "type": "array", "items": { "type": "string" } },
    "validation_plan": { "type": "array", "items": { "type": "string" } },
    "validation_priority": { "type": "array", "items": { "type": "string" } },
    "overlap_risks": { "type": "array", "items": { "type": "string" } },
    "recommendation": { "type": "string" },
    "target_files": { "type": "array", "items": { "type": "string" } },
    "depth_metrics": { "type": "object" }
  },
  "additionalProperties": true
}
