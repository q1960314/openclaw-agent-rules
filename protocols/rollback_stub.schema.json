{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Rollback Stub Schema",
  "required": [
    "task_id",
    "rollback_supported",
    "rollback_artifacts",
    "official_release",
    "note"
  ],
  "properties": {
    "task_id": { "type": "string" },
    "rollback_supported": { "type": "boolean" },
    "rollback_artifacts": { "type": "array", "items": { "type": "string" } },
    "official_release": { "type": "boolean" },
    "candidate_only": { "type": "boolean" },
    "note": { "type": "string" }
  },
  "additionalProperties": true
}
