{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Human Approval Input Slot Schema",
  "required": ["task_id", "slot_ready", "input_recorded", "accepted_decisions", "next_step"],
  "properties": {
    "task_id": {"type": "string"},
    "slot_ready": {"type": "boolean"},
    "input_recorded": {"type": "boolean"},
    "decision_value": {"type": ["boolean", "null"]},
    "accepted_decisions": {"type": "array", "items": {"type": "string"}},
    "current_state": {"type": "string"},
    "next_step": {"type": "string"},
    "note": {"type": "string"}
  },
  "additionalProperties": true
}
