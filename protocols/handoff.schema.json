{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "P1 Handoff Schema",
  "required": [
    "task_id",
    "from",
    "to",
    "artifacts",
    "summary"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "from": {
      "type": "string"
    },
    "to": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}