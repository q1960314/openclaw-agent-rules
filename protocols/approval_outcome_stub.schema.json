{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Approval Outcome Stub Schema",
  "required": ["task_id", "approval_status", "approved", "requires_human_approval", "next_step"],
  "properties": {
    "task_id": {"type": "string"},
    "approval_status": {"type": "string", "enum": ["not_ready_for_approval", "pending_human_approval", "approved_stub"]},
    "approved": {"type": "boolean"},
    "requires_human_approval": {"type": "boolean"},
    "next_step": {"type": "string"},
    "note": {"type": "string"}
  },
  "additionalProperties": true
}
