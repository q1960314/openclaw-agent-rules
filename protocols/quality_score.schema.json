{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Quality Score Schema",
  "required": [
    "task_id",
    "role",
    "review_decision",
    "score",
    "grade",
    "dimensions",
    "blocking_flags",
    "summary"
  ],
  "properties": {
    "task_id": { "type": "string" },
    "role": { "type": "string" },
    "review_decision": { "type": "string" },
    "score": { "type": "integer" },
    "grade": { "type": "string", "enum": ["A", "B", "C", "D", "F"] },
    "dimensions": {
      "type": "object",
      "required": ["artifact_completeness", "structural_quality", "validation_outcome", "release_readiness"],
      "properties": {
        "artifact_completeness": { "type": "integer" },
        "structural_quality": { "type": "integer" },
        "validation_outcome": { "type": "integer" },
        "release_readiness": { "type": "integer" }
      },
      "additionalProperties": true
    },
    "blocking_flags": { "type": "array", "items": { "type": "string" } },
    "summary": { "type": "string" },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
