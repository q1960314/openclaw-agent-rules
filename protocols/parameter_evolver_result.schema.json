{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Parameter Evolver Result Schema",
  "required": [
    "task_id",
    "objective",
    "candidate_summary",
    "parameter_objective",
    "sensitive_parameters",
    "sensitivity_rationales",
    "robust_ranges",
    "fragile_ranges",
    "range_justification",
    "tuning_sequence",
    "boundary_design",
    "metric_guardrails",
    "code_touchpoints",
    "change_priority",
    "backtest_handoff",
    "validation_plan",
    "risk_notes",
    "target_files"
  ],
  "properties": {
    "task_id": { "type": "string" },
    "objective": { "type": "string" },
    "mode": { "type": "string" },
    "model": { "type": "string" },
    "candidate_summary": { "type": "string" },
    "parameter_objective": { "type": "string" },
    "sensitive_parameters": { "type": "array", "items": { "type": "string" } },
    "sensitivity_rationales": { "type": "array", "items": { "type": "string" } },
    "robust_ranges": { "type": "array", "items": { "type": "string" } },
    "fragile_ranges": { "type": "array", "items": { "type": "string" } },
    "range_justification": { "type": "array", "items": { "type": "string" } },
    "tuning_sequence": { "type": "array", "items": { "type": "string" } },
    "boundary_design": { "type": "array", "items": { "type": "string" } },
    "metric_guardrails": { "type": "array", "items": { "type": "string" } },
    "code_touchpoints": { "type": "array", "items": { "type": "string" } },
    "change_priority": { "type": "array", "items": { "type": "string" } },
    "backtest_handoff": { "type": "array", "items": { "type": "string" } },
    "validation_plan": { "type": "array", "items": { "type": "string" } },
    "risk_notes": { "type": "array", "items": { "type": "string" } },
    "target_files": { "type": "array", "items": { "type": "string" } },
    "depth_metrics": { "type": "object" }
  },
  "additionalProperties": true
}
